{
  "name": "coo-assistant",
  "version": "1.0.0",
  "description": "AI-powered COO Assistant for internal operations management",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "google:auth": "tsx scripts/google-oauth.ts",
    "setup": "bash scripts/setup.sh",
    "browser:login": "tsx scripts/browser-login.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@notionhq/client": "^5.14.0",
    "@slack/bolt": "^4.6.0",
    "@types/pdfkit": "^0.17.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "googleapis": "^171.4.0",
    "ioredis": "^5.10.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.18.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.59.1",
    "postgres": "^3.4.8",
    "telegram": "^2.26.16",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true
}
