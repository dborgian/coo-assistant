# ═══════════════════════════════════════════════
# COO Assistant — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Run `npm run setup` for interactive setup.

# ─── REQUIRED ──────────────────────────────────

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_OWNER_CHAT_ID=your-telegram-chat-id

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key
AGENT_MODEL=claude-sonnet-4-20250514

# Supabase PostgreSQL (use SHARED POOLER, port 6543)
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── OPTIONAL: Telegram Chat Monitoring ────────

# GramJS userbot (https://my.telegram.org for API ID/Hash)
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
MONITORED_CHAT_IDS=[]

# ─── OPTIONAL: Google Workspace ────────────────

# Google OAuth2 (Calendar R/W, Gmail, Drive, Sheets)
# Run `npm run google:auth` after setting client ID/secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
GOOGLE_REFRESH_TOKEN=

# Google Drive folders for reports
COO_DRIVE_FOLDER_ID=
DRIVE_DAILY_FOLDER_ID=
DRIVE_EMPLOYEE_FOLDER_ID=

# ─── OPTIONAL: Slack ──────────────────────────

# Slack Bot (Socket Mode — create at api.slack.com/apps)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
MONITORED_SLACK_CHANNELS=[]
SLACK_NOTIFICATIONS_CHANNEL=

# ─── OPTIONAL: Notion ─────────────────────────

# Notion integration (https://www.notion.so/my-integrations)
NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
NOTION_PROJECTS_DATABASE_ID=
NOTION_SYNC_INTERVAL_MINUTES=15

# ─── SCHEDULING & OPERATIONS ──────────────────

MESSAGE_RETENTION_DAYS=90
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0
TIMEZONE=Europe/Rome
CHAT_CHECK_INTERVAL_MINUTES=5
CALENDAR_CHECK_INTERVAL_MINUTES=15
EMAIL_CHECK_INTERVAL_MINUTES=10
