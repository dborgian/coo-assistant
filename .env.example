# ═══════════════════════════════════════════════
# COO Assistant — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Run `npm run setup` for interactive setup.

# ─── REQUIRED ──────────────────────────────────

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key
AGENT_MODEL=claude-sonnet-4-20250514

# Supabase PostgreSQL (use SHARED POOLER, port 6543)
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Slack Bot (Socket Mode — create at api.slack.com/apps)
# Required: Bot Token Scopes: chat:write, commands, files:write, im:write, users:read, channels:read, reactions:write
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# ─── OPTIONAL: Slack ──────────────────────────

# Channel to post notifications in (fallback if owner DM fails)
SLACK_NOTIFICATIONS_CHANNEL=C0XXXXXXXXX
# Comma-separated channel IDs to monitor for AI classification
MONITORED_SLACK_CHANNELS=[]
# Owner's Slack Member ID (auto-resolved from DB if empty)
SLACK_OWNER_MEMBER_ID=

# ─── OPTIONAL: Google Workspace ────────────────

# Google OAuth2 (Calendar R/W, Gmail, Drive, Sheets)
# Run `npm run google:auth` after setting client ID/secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app.railway.app/oauth/callback
GOOGLE_REFRESH_TOKEN=

# Google Drive folders for reports
COO_DRIVE_FOLDER_ID=
DRIVE_DAILY_FOLDER_ID=
DRIVE_EMPLOYEE_FOLDER_ID=

# ─── OPTIONAL: Notion ─────────────────────────

# Notion integration (https://www.notion.so/my-integrations)
NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
NOTION_PROJECTS_DATABASE_ID=
NOTION_MEETING_ACTIONS_DATABASE_ID=
NOTION_SYNC_INTERVAL_MINUTES=15

# ─── OPTIONAL: Redis ──────────────────────────

# Redis for persistent conversation history (ioredis)
# If not set, falls back to in-memory cache (lost on restart)
REDIS_URL=

# ─── SCHEDULING & OPERATIONS ──────────────────

MESSAGE_RETENTION_DAYS=90
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0
TIMEZONE=Europe/Rome
CHAT_CHECK_INTERVAL_MINUTES=5
CALENDAR_CHECK_INTERVAL_MINUTES=15
EMAIL_CHECK_INTERVAL_MINUTES=10
