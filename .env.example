# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_OWNER_CHAT_ID=your-telegram-chat-id

# GramJS (userbot for monitoring group chats)
TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash
# Leave empty on first run — the app will prompt for login and print the session string
TELEGRAM_SESSION_STRING=
MONITORED_CHAT_IDS=[]

# Anthropic (Claude API for AI reasoning)
ANTHROPIC_API_KEY=your-anthropic-api-key
AGENT_MODEL=claude-sonnet-4-20250514

# Google OAuth2 (for Calendar & Gmail MCP)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback

# Kanbanchi
KANBANCHI_API_KEY=your-kanbanchi-api-key
KANBANCHI_BOARD_ID=your-kanbanchi-board-id

# Database
DATABASE_PATH=./data/coo.db

# Operations Config
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0
TIMEZONE=America/New_York
CHAT_CHECK_INTERVAL_MINUTES=5
CALENDAR_CHECK_INTERVAL_MINUTES=15
